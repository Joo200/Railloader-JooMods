<Project>
  <PropertyGroup>
    <!-- Try to find the directory on our own -->
    <GameManagedDir Condition="'$(GameManagedDir)' == ''">$([System.IO.Directory]::GetDirectories(`$(GameDir)`, `*_Data`)[0])\Managed</GameManagedDir>
    
    <!-- Copy the mod to the game directory -->
    <GameModDir Condition="'$(GameModDir)' == ''">$(GameDir)/Mods/$(AssemblyName)</GameModDir>
  </PropertyGroup>

  <Target Name="CopyToGame" AfterTargets="AfterBuild" Condition="'$(Configuration)' == 'Debug'">
    <ItemGroup>
      <DebugFiles Include="$(OutputPath)/**/*" Exclude="$(OutputPath)/**/*.pdb;$(OutputPath)/**/*.xml" />
    </ItemGroup>
    <Copy SourceFiles="@(DebugFiles)" DestinationFolder="$(GameModDir)" />
  </Target>

  <!-- Replace the default version if something was set for it -->
  <PropertyGroup Condition="'$(AssemblyVersion)' == '' OR '$(MajorVersion)' != '' OR '$(MinorVersion)' != ''">
    <MajorVersion Condition="'$(MajorVersion)' == ''">1</MajorVersion>
    <MinorVersion Condition="'$(MinorVersion)' == ''">0</MinorVersion>
    <AssemblyVersion>$(MajorVersion).$(MinorVersion).$([System.DateTime]::UtcNow.ToString(yy))$([System.DateTime]::UtcNow.DayOfYear.ToString("000")).$([System.DateTime]::UtcNow.ToString("Hmm").TrimStart('0'))</AssemblyVersion>
    <FileVersion>$(AssemblyVersion)</FileVersion>
    <ProductVersion>$(AssemblyVersion)</ProductVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Reference the .dll/.exes specified with GameAssembly elements-->
    <Reference Include="@(GameAssembly)">
      <HintPath Condition="Exists('$(GameManagedDir)\%(Identity).dll')">$(GameManagedDir)\%(Identity).dll</HintPath>
      <HintPath Condition="Exists('$(GameManagedDir)\%(Identity).exe')">$(GameManagedDir)\%(Identity).exe</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- Publish the mod as a neat zip file -->
  <Target Name="PrepareForPublishing" AfterTargets="AfterBuild" Condition="'$(Configuration)' == 'Release' OR '$(Configuration)' == 'PublishRelease'">    
    <!-- Replace $(AssemblyVersion) with the actual version -->
    <Exec Command="powershell -Command &quot;(Get-Content '$(OutputPath)Definition.json') -replace '\$\(AssemblyVersion\)', '$(AssemblyVersion)' | Set-Content '$(OutputPath)Definition.json'&quot;" Condition="Exists('$(OutputPath)Definition.json')" />

    <PropertyGroup Condition="'$(SkipPublishing)' != 'true'">
      <ModsDirectory>$(OutputPath)/Mods</ModsDirectory>
      <ModDirectory>$(ModsDirectory)/$(AssemblyName)</ModDirectory>

      <!-- Folder we'll put the published zips into -->
      <PublishPath>../bin</PublishPath>
      <ZipName>$(PublishPath)/$(AssemblyName)_$(AssemblyVersion).zip</ZipName>
    </PropertyGroup>

    <!-- Assure the output path exists -->
    <MakeDir Directories="$(PublishPath)" />
    
    <!-- Remove the old Mods directory, and Zips file if any is lying around -->
    <ItemGroup>
      <OldZips Include="$(PublishPath)/$(AssemblyName)_*.zip" />
    </ItemGroup>
    
    <RemoveDir Directories="$(ModsDirectory)"  ContinueOnError="true" />
    <Delete Files="@(OldZips)" />
    
    <!-- Create the Mods directory again -->
    <MakeDir Directories="$(ModDirectory)" />

    <!-- Move all files to the right folder -->
    <ItemGroup>
      <OutputFiles Include="$(OutputPath)/**/*" Exclude="$(OutputPath)/**/*.pdb;$(OutputPath)/**/*.xml" />
      <OutputFiles Condition="'$(AssemblyName)' == 'InterchangeReloader'" Remove="$(OutputPath)/*.dll" />
      <OutputFiles Condition="'$(AssemblyName)' == 'InterchangeReloader' AND Exists('$(OutputPath)InterchangeReloader.dll')" Include="$(OutputPath)InterchangeReloader.dll" />
      <OutputFiles Condition="'$(AssemblyName)' == 'InterchangeReloader' AND Exists('$(OutputPath)InterchangeReloaderSkom.dll')" Include="$(OutputPath)InterchangeReloaderSkom.dll" />
    </ItemGroup>

    <Copy SourceFiles="@(OutputFiles)" DestinationFolder="$(ModDirectory)" Condition="'$(SkipPublishing)' != 'true' AND '@(OutputFiles)' != ''" />

    <!-- Zip it up -->
    <Exec Command="powershell -Command &quot;Compress-Archive -Path '$(ModsDirectory)' -Destination '$(ZipName)'&quot;" Condition="'$(SkipZip)' != 'true' AND '$(SkipPublishing)' != 'true'" />
    
    <!-- Move them to the game directory -->
    <Copy SourceFiles="@(OutputFiles)" DestinationFolder="$(GameModDir)" Condition="'$(SkipPublishing)' != 'true'" />
  </Target>
  <Target Name="PublishReleaseTarget" AfterTargets="PrepareForPublishing" Condition="'$(Configuration)' == 'PublishRelease'">
    <PropertyGroup>
      <RepoUrl>git@github.com:Joo200/Railloader.TimeSync.git</RepoUrl>
      <!-- Create a tag based on the year, day of year, hh and mm in utc -->
      <PublishTag>$([System.DateTime]::UtcNow.ToString(yy))$([System.DateTime]::UtcNow.DayOfYear.ToString("000")).$([System.DateTime]::UtcNow.ToString("Hmm").TrimStart('0'))</PublishTag>
    </PropertyGroup>

    <ItemGroup>
      <ZipFiles Include="../bin/*.zip" />
    </ItemGroup>

    <!-- 1. Remove every content in the bin directory -->
    <!-- This is handled by a separate target that runs BeforeBuild -->

    <!-- 2. Validate that the project is not dirty (no uncommited git changes) -->
    <Exec Command="git diff --quiet" IgnoreExitCode="false">
      <Output TaskParameter="ExitCode" PropertyName="GitDiffExitCode" />
    </Exec>
    <Error Text="Project is dirty. Please commit or stash your changes before publishing." Condition="'$(GitDiffExitCode)' != '0'" />

    <!-- 3. Validate that the commit is pushed to github -->
    <!-- Check if the current local branch is in sync with its remote tracking branch -->
    <Exec Command="powershell -Command &quot;if (git status -uno | Select-String 'Your branch is ahead of') { Write-Error 'Current branch has unpushed commits.'; exit 1 }&quot;" IgnoreExitCode="false" />

    <!-- 4. Build the project as release -->
    <!-- This is already happening because this target runs AfterBuild in PublishRelease configuration -->

    <!-- 5. Create a release and upload every zip file in bin directory -->
    <Message Text="Checking if GitHub release $(PublishTag) exists..." Importance="high" />
    <Exec Command="powershell -Command &quot;gh release view $(PublishTag) --repo $(RepoUrl)&quot;" IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="ReleaseExistsExitCode" />
    </Exec>

    <Message Text="Creating GitHub release $(PublishTag) and uploading zips..." Importance="high" Condition="'$(ReleaseExistsExitCode)' != '0'" />
    <Exec Command="powershell -Command &quot;$zips = Get-ChildItem ../bin/*.zip | Select-Object -ExpandProperty FullName; if ($zips) { gh release create $(PublishTag) --title 'Release $(PublishTag)' --notes 'Manual release' $zips } else { gh release create $(PublishTag) --title 'Release $(PublishTag)' --notes 'Manual release' }&quot;" Condition="'$(ReleaseExistsExitCode)' != '0'" />

    <Message Text="Uploading zips to existing GitHub release $(PublishTag)..." Importance="high" Condition="'$(ReleaseExistsExitCode)' == '0'" />
    <Exec Command="powershell -Command &quot;$zips = Get-ChildItem ../bin/*.zip | Select-Object -ExpandProperty FullName; if ($zips) { gh release upload $(PublishTag) $zips --clobber }&quot;" Condition="'$(ReleaseExistsExitCode)' == '0'" />
  </Target>

  <Target Name="CleanBinBeforePublish" BeforeTargets="BeforeBuild" Condition="'$(Configuration)' == 'PublishRelease'">
    <Message Text="Cleaning bin directory before PublishRelease..." Importance="high" />
    <ItemGroup>
      <MyOldZips Include="$(PublishPath)/$(AssemblyName)_*.zip" />
    </ItemGroup>
    <Delete Files="@(MyOldZips)" />
    <!-- Also remove directories in bin that belong to this project -->
    <RemoveDir Directories="$(ModsDirectory)"  ContinueOnError="true" />
  </Target>
</Project>